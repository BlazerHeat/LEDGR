// LEDGR — Prisma schema (Postgres / Supabase)
// Generator switched to the Python client for the FastAPI backend.
// Datasource keeps the supplied transaction-pooler URL for runtime and the
// session-pooler DIRECT_URL for migrations / `db push`.

generator client {
  provider                    = "prisma-client-py"
  interface                   = "asyncio"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum TxnType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  DEBIT_CARD
  CREDIT_CARD
  CASH
  E_TRANSFER
  DIRECT_DEPOSIT
  PRE_AUTH
  OTHER
}

enum ReceiptSource {
  OCR
  MANUAL
}

enum ReceiptStatus {
  PROCESSING
  SCANNED
  CONFIRMED
  FAILED
}

enum GroupStatus {
  ACTIVE
  SETTLED
  ARCHIVED
}

enum MemberRole {
  OWNER
  MEMBER
}

enum SplitMode {
  ITEMISED
  EQUAL
  EXACT
  PERCENT
  SHARES
}

enum TaxAllocation {
  PROPORTIONAL
  EQUAL
}

enum SettlementStatus {
  PENDING
  SETTLED
}

// ---------------------------------------------------------------------------
// Security / identity
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  avatarColor  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories          Category[]
  budgets             Budget[]
  transactions        Transaction[]
  receipts            Receipt[]
  ownedGroups         Group[]              @relation("GroupOwner")
  memberships         GroupMember[]
  createdSplits       Split[]              @relation("SplitCreator")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Feature 1 — Personal Ledger
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#6366F1")
  icon      String?
  parentId  String?
  parent    Category?  @relation("Subcategory", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("Subcategory")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@map("categories")
}

model Budget {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month           String   // "YYYY-MM"
  targetAmount    Decimal  @db.Decimal(12, 2)
  rolloverEnabled Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, categoryId, month])
  @@index([userId])
  @@map("budgets")
}

model Transaction {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TxnType
  amount        Decimal       @db.Decimal(12, 2)
  vendor        String
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date          DateTime
  paymentMethod PaymentMethod @default(OTHER)
  note          String?
  isShared      Boolean       @default(false)
  receiptId     String?
  receipt       Receipt?      @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  splitId       String?
  split         Split?        @relation(fields: [splitId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, date])
  @@index([userId, categoryId])
  @@map("transactions")
}

// ---------------------------------------------------------------------------
// Feature 2 — Split Studio (receipts, groups, splits, balances)
// ---------------------------------------------------------------------------

model Receipt {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant  String
  date      DateTime
  subtotal  Decimal       @db.Decimal(12, 2)
  tax       Decimal       @db.Decimal(12, 2)
  total     Decimal       @db.Decimal(12, 2)
  imageUrl  String?
  source    ReceiptSource @default(MANUAL)
  status    ReceiptStatus @default(PROCESSING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lineItems    ReceiptLineItem[]
  transactions Transaction[]
  splits       Split[]

  @@index([userId])
  @@map("receipts")
}

model ReceiptLineItem {
  id        String  @id @default(cuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal @db.Decimal(12, 2)
  quantity  Int     @default(1)

  @@index([receiptId])
  @@map("receipt_line_items")
}

model Group {
  id        String      @id @default(cuid())
  name      String
  ownerId   String
  owner     User        @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  status    GroupStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  members     GroupMember[]
  splits      Split[]
  settlements Settlement[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  id          String     @id @default(cuid())
  groupId     String
  group       Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String? // null = unregistered placeholder participant
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName String
  avatarColor String?
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  itemShares        SplitItemShare[]
  participantShares SplitParticipantShare[]
  settlementsFrom   Settlement[]            @relation("SettlementFrom")
  settlementsTo     Settlement[]            @relation("SettlementTo")

  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model Split {
  id            String        @id @default(cuid())
  groupId       String
  group         Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  receiptId     String?
  receipt       Receipt?      @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User          @relation("SplitCreator", fields: [createdById], references: [id], onDelete: Cascade)
  title         String
  mode          SplitMode     @default(ITEMISED)
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  taxAllocation TaxAllocation @default(PROPORTIONAL)
  date          DateTime
  createdAt     DateTime      @default(now())

  items             SplitItem[]
  participantShares SplitParticipantShare[]
  transactions      Transaction[]

  @@index([groupId])
  @@map("splits")
}

model SplitItem {
  id       String  @id @default(cuid())
  splitId  String
  split    Split   @relation(fields: [splitId], references: [id], onDelete: Cascade)
  label    String
  amount   Decimal @db.Decimal(12, 2)
  quantity Int     @default(1)

  shares SplitItemShare[]

  @@index([splitId])
  @@map("split_items")
}

model SplitItemShare {
  id          String      @id @default(cuid())
  splitItemId String
  splitItem   SplitItem   @relation(fields: [splitItemId], references: [id], onDelete: Cascade)
  memberId    String
  member      GroupMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  weight      Float       @default(1)

  @@unique([splitItemId, memberId])
  @@index([memberId])
  @@map("split_item_shares")
}

model SplitParticipantShare {
  id       String      @id @default(cuid())
  splitId  String
  split    Split       @relation(fields: [splitId], references: [id], onDelete: Cascade)
  memberId String
  member   GroupMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount   Decimal     @db.Decimal(12, 2)

  @@unique([splitId, memberId])
  @@index([memberId])
  @@map("split_participant_shares")
}

model Settlement {
  id           String           @id @default(cuid())
  groupId      String
  group        Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromMemberId String
  fromMember   GroupMember      @relation("SettlementFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMemberId   String
  toMember     GroupMember      @relation("SettlementTo", fields: [toMemberId], references: [id], onDelete: Cascade)
  amount       Decimal          @db.Decimal(12, 2)
  status       SettlementStatus @default(PENDING)
  settledAt    DateTime?
  createdAt    DateTime         @default(now())

  @@index([groupId])
  @@map("settlements")
}

# LEDGR API — environment template. Copy to `.env` and fill in real values.

# Postgres via the shared transaction-mode pooler (IPv4-only) — used at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Postgres via the shared session-mode pooler — used for migrations / db push
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Auth — generate a strong random secret, e.g. `python -c "import secrets;print(secrets.token_hex(32))"`
JWT_SECRET="change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# App
ENVIRONMENT="development"
CORS_ORIGINS="*"
